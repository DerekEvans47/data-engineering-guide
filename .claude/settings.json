{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cp .claude/skills/pre-commit-hook.sh .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit"
          },
          {
            "type": "command",
            "command": "cp .claude/skills/pre-push-hook.sh .git/hooks/pre-push && chmod +x .git/hooks/pre-push"
          }
        ]
      }
    ]
  }
}
