{
  "_design_notes": {
    "max_sheet_size": "4x4",
    "cell_size_px": 256,
    "target_deco_density": "35-40% of non-path cells",
    "sheets_per_theme": 2,
    "total_sprites": 96,
    "themes": {
      "verdant": "Parts 1-3 — living forest, lush and natural. Sheet 1: naturalistic. Sheet 2: magical/fantastical.",
      "decay": "Parts 4-6 — graveyard, medieval decay, death.",
      "void": "Parts 7-9 — otherworldly, cosmic horror, eldritch."
    },
    "size_render_scale": {
      "large": 0.85,
      "medium": 0.60,
      "small": 0.35
    },
    "placement_rules": {
      "anywhere": "Scattered freely by seeded RNG",
      "open": "Needs clear space — not adjacent to other large sprites",
      "path-adjacent": "Placed within 1 cell of path edge"
    },
    "animation_approach": {
      "canvas-math": "Driven by bgTime — glow-pulse, flicker, rotate, scale-breathe, float. No extra assets.",
      "sprite-frames": "Frame strip sheet required. Reserved for shape-changing animations (blink, flame, water ripple)."
    },
    "animation_types": {
      "glow-pulse": "opacity sine wave on bgTime",
      "flicker-rotate": "opacity jitter + slow rotation",
      "ripple": "radial scale pulse",
      "rotate": "continuous slow rotation",
      "scale-breathe": "gentle scale sine wave",
      "blink": "SPRITE FRAMES REQUIRED — not yet implemented"
    }
  },
  "sheets": {
    "verdant-1": {
      "file": "deco-verdant-1.png",
      "cols": 4, "rows": 4, "cellSize": 256,
      "sprites": {
