{
  "_design_notes": {
    "max_sheet_size": "4x4",
    "cell_size_px": 256,
    "target_deco_density": "35-40% of non-path cells",
    "sheets_per_theme": 2,
    "total_sprites": 96,
    "themes": {
      "verdant": "Parts 1-3 — living forest, lush and natural. Sheet 1: naturalistic. Sheet 2: magical/fantastical.",
      "decay": "Parts 4-6 — graveyard, medieval decay, death.",
      "void": "Parts 7-9 — otherworldly, cosmic horror, eldritch."
    },
    "size_render_scale": {
      "large": 0.85,
      "medium": 0.60,
      "small": 0.35
    },
    "placement_rules": {
      "anywhere": "Scattered freely by seeded RNG",
      "open": "Needs clear space — not adjacent to other large sprites",
      "path-adjacent": "Placed within 1 cell of path edge"
    },
    "animation_approach": {
      "canvas-math": "Driven by bgTime — glow-pulse, flicker, rotate, scale-breathe, float. No extra assets.",
      "sprite-frames": "Frame strip sheet required. Reserved for shape-changing animations (blink, flame, water ripple)."
    },
    "animation_types": {
      "glow-pulse": "opacity sine wave on bgTime",
      "flicker-rotate": "opacity jitter + slow rotation",
      "ripple": "radial scale pulse",
      "rotate": "continuous slow rotation",
      "scale-breathe": "gentle scale sine wave",
      "blink": "SPRITE FRAMES REQUIRED — not yet implemented"
    }
  },
  "sheets": {
    "verdant-1": {
      "file": "deco-verdant-1.png",
      "cols": 4, "rows": 4, "cellSize": 256,
      "sprites": {
        "tree-large":    { "pos": [0,0], "size": "large",  "placement": "anywhere" },
        "boulder":       { "pos": [1,0], "size": "large",  "placement": "anywhere" },
        "bush-dense":    { "pos": [2,0], "size": "medium", "placement": "anywhere" },
        "flowers":       { "pos": [3,0], "size": "medium", "placement": "anywhere" },
        "tree-small":    { "pos": [0,1], "size": "small",  "placement": "anywhere" },
        "rock-small":    { "pos": [1,1], "size": "small",  "placement": "anywhere" },
        "grass-tuft":    { "pos": [2,1], "size": "small",  "placement": "anywhere" },
        "fern":          { "pos": [3,1], "size": "medium", "placement": "anywhere" },
        "log":           { "pos": [0,2], "size": "medium", "placement": "anywhere" },
        "mushroom-ring": { "pos": [1,2], "size": "medium", "placement": "open" },
        "forest-pool":   { "pos": [2,2], "size": "medium", "placement": "open" },
        "roots":         { "pos": [3,2], "size": "medium", "placement": "anywhere" },
        "pillar":        { "pos": [0,3], "size": "medium", "placement": "anywhere" },
        "berry-bush":    { "pos": [1,3], "size": "medium", "placement": "anywhere" },
        "lily-pads":     { "pos": [2,3], "size": "medium", "placement": "open" },
        "hedge-arch":    { "pos": [3,3], "size": "large",  "placement": "anywhere" }
      }
    },
    "verdant-2": {
      "file": "deco-verdant-2.png",
      "cols": 4, "rows": 4, "cellSize": 256,
      "sprites": {
        "crystals":       { "pos": [0,0], "size": "medium", "placement": "anywhere" },
        "stump-large":    { "pos": [1,0], "size": "large",  "placement": "anywhere" },
        "mushrooms-fan":  { "pos": [2,0], "size": "medium", "placement": "anywhere" },
        "lantern-pods":   { "pos": [3,0], "size": "small",  "placement": "anywhere" },
        "foxgloves":      { "pos": [0,1], "size": "medium", "placement": "anywhere" },
        "rune-stone":     { "pos": [1,1], "size": "medium", "placement": "anywhere" },
        "glowing-moss":   { "pos": [2,1], "size": "small",  "placement": "open" },
        "signpost":       { "pos": [3,1], "size": "small",  "placement": "path-adjacent" },
        "fern-large":     { "pos": [0,2], "size": "large",  "placement": "anywhere" },
        "mushroom-ring2": { "pos": [1,2], "size": "medium", "placement": "open" },
        "pond":           { "pos": [2,2], "size": "large",  "placement": "open" },
        "vines":          { "pos": [3,2], "size": "medium", "placement": "anywhere" },
        "bridge":         { "pos": [0,3], "size": "large",  "placement": "path-adjacent" },
        "flower-bush":    { "pos": [1,3], "size": "medium", "placement": "anywhere" },
        "cattails":       { "pos": [2,3], "size": "small",  "placement": "path-adjacent" },
        "stone-arch":     { "pos": [3,3], "size": "large",  "placement": "path-adjacent" }
      }
    }
  }
}
